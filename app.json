{
  "expo": {
    "name": "Vinyly",
    "slug": "record_collection_app",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "recordcollection",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#111111"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan vinyl record barcodes",
        "NSPhotoLibraryUsageDescription": "Used to set your collection profile photo",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.jonesfamily.recordcollection"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Used to scan vinyl record barcodes"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a9c63d3c-adc1-4f92-9ddf-ca06e87e1d63"
      }
    }
  }
}
